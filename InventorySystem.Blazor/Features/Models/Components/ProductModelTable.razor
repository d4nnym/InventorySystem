@using InventorySystem.Blazor.Features.Models.Contracts
@using Microsoft.AspNetCore.Components.Web;
@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
}
else if (_error is not null)
{
    <p style="color:red">@_error</p>
}
else if (_modelDetails.Count == 0)
{
    <p>No details yet.</p>
}
else
{
    <MudTable Items="@_modelDetails" Hover="true" Bordered="false" Filter="new Func<ProductModelDetailResponse, bool>(FilterFunc1)" @bind-SelectedItem="selectedItem1">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Buscar Elemento</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="searchString1" Placeholder="Buscar" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" @onkeydown="HandleKeyDown" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Categoría</MudTh>
            <MudTh>Marca</MudTh>
            <MudTh>Modelo</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Categoría">@context.CategoryName</MudTd>
            <MudTd DataLabel="Marca">@context.BrandName</MudTd>
            <MudTd DataLabel="Modelo">@context.ModelName</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            searchString1 = "";
        }
    }

}
